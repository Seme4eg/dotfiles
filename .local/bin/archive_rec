#!/usr/bin/sh

trapfn() {
  pkill easyeffects
}

# Trap the SIGINT signal (Ctrl+C) and run the cleanup function
trap 'trapfn' INT HUP

echo "WAIT FOR FFMPEG LOGS TO APPEAR, THEN RECORD ..."

if ! pgrep -x easyeffects >/dev/null; then
  easyeffects -w >/dev/null 2>&1 &
  sleep 2
fi

name="$1"
datetime=$(date +'%Y-%m-%d %H.%M.%S')
ffmpeg -f pulse -i default ~/"$datetime ${name:-default_recording}".mp3
