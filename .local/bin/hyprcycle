#!/usr/bin/sh

direction=$1 # prev / next
layout=$(hyprctl activeworkspace -j | gojq -r '.tiledLayout')

has_floating() {
  cur_workspace=$(hyprctl activeworkspace -j | gojq '.id')
  count=$(hyprctl clients -j |
    gojq "[.[] | select(.workspace.id == $cur_workspace and .floating == true and .pinned == false)] | length")
  [ "$count" -gt 0 ]
}

if has_floating; then
  hyprctl dispatch "hl.dsp.window.cycle_next(\"$direction\")"
  exit
fi

case $layout in
  monocle)
    hyprctl dispatch "hl.dsp.layout(\"cycle$direction\")"
    exit
    ;;
  scrolling)
    direction_opt=$(hyprctl getoption scrolling:direction | head -n1 | cut -d' ' -f2)
    _direction=
    if [ $direction = "prev" ]; then
      [ $direction_opt = down ] && _direction=up || _direction=left
    else
      [ $direction_opt = down ] && _direction=down || _direction=right
    fi
    hyprctl dispatch "hl.dsp.layout(\"focus $_direction\")"
    exit
    ;;
  master)
    hyprctl dispatch "hl.dsp.layout(\"roll$direction\")"
    exit
    ;;
esac
