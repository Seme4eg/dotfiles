#!/usr/bin/bash

# bit of debugging advise
# - NOTE: if zapret service works on 'any' interface (means on all) - it will
#    BREAK localhost vnc setup, you will just see black screen
# - to debug:
#   - remove all &>/dev/null-s (BUT DON'T TO PUT & WHERE ITS NEEDED)
#   - add '-L debug' to wayvnc command
# - use 'adb shell wm size' to get native device resolution in case you will be scripting all that

port=5900

output_name="vnc_pixel"
position="auto-center-right"
# NOTE: 120 fps for phone outputs cuz hyprland might sometimes lower main
# monitor to match refresh rate of 2nd monitor
refresh=120
scale=1

is_pixel() { adb devices -l | grep -w -q Pixel_9; }
# TODO:
# is_nothing() { adb devices -l | grep -w -q ???; }
is_samsung() { adb devices -l | grep -w -q SM_T555; }

if is_samsung; then
  output_name="vnc_samsung"
  position="auto-center-down"
  refresh=60
fi

cable_connected() {
  # sometimes needed to refresh device list
  adb kill-server &>/dev/null
  adb start-server &>/dev/null
  adb devices | grep -w -q device
}

if is_pixel && cable_connected; then
  scale=1.5
fi

# if internet connection - always lower fps
cable_connected && refresh=60

device_mode() {
  if ! cable_connected; then
    echo preferred
    return 0
  fi

  out="$(adb shell wm size | cut -d':' -f 2 | tr -d '\r ' | tail -n1)"
  h=${out%x*}
  w=${out#*x}

  d=1
  [ $w -gt 1100 ] && d=2

  size="$((w / d))x$((h / d))"

  printf '%s@%s' "$size" "$refresh"
}

# per-phone corner rounding (phone screen cutout / aesthetic)
rounding=20 # default / CMF
if cable_connected; then
  if is_samsung; then
    rounding=5
  elif is_pixel; then
    rounding=42
  fi
fi

state_file="$HOME/.cache/hypr-vnc-state.lua"
cat >"$state_file" <<EOF
hl.monitor({
  output = "${output_name}",
  mode = "$(device_mode)",
  bitdepth = 10,
  cm = "auto",
  position = "${position}",
  scale = ${scale},
})

hl.window_rule({
  match = {
    workspace = "m[${output_name}]",
  },
  rounding = ${rounding},
})

-- vnc monitors convenience
hl.bind("SUPER + CTRL + 4", hl.dsp.window.fullscreen({ mode = "maximized", action = "toggle" }))
hl.bind("SUPER + SHIFT + 4", hl.dsp.window.fullscreen({ mode = "maximized", action = "toggle" }))
EOF

hyprctl reload &>/dev/null

vnc_stop() {
  hyprctl output remove $output_name >/dev/null
  rm -f "$state_file"
  pkill wayvnc
  if ! cable_connected; then
    sudo ufw delete allow $port/tcp >/dev/null
    sudo ufw reload >/dev/null
  fi
  echo "Cleanup finished. Exiting."
  exit 0
}

trapfn() {
  echo "
Interrupt received. Performing cleanup..."
  vnc_stop
}

# Trap the SIGINT signal (Ctrl+C) and run the cleanup function
trap 'trapfn' INT HUP TERM

hyprctl output create headless $output_name >/dev/null
wayvnc -dp -f 120 -o $output_name &>/dev/null & # -g
# DEBUG:
# wayvnc -dp -L debug -o "$output_name" &

# if phone connected via usb - reverse socket connection
if cable_connected; then
  adb reverse tcp:$port tcp:$port >/dev/null
else
  # output the machine ip on current network
  ip route get 1 | sed -n '1p'
  sudo ufw allow $port/tcp >/dev/null
  sudo ufw reload >/dev/null
fi

sleep 0.2

read -p "Press Enter to continue..."

vnc_stop
