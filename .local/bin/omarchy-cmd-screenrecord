#!/bin/bash

# man gpu-screen-recorder
# https://git.dec05eba.com/gpu-screen-recorder/about/

rec_dir="$HOME/Pictures/DCIM"
[ ! -d "$rec_dir" ] && mkdir "$rec_dir"

SCOPE="region"
DESKTOP_AUDIO="false"
MICROPHONE_AUDIO="false"
RECORDING_FILE="/tmp/omarchy-screenrecord-filename"
proc_name="^gpu-screen-recorder"

for arg in "$@"; do
  case "$arg" in
    --with-desktop-audio) DESKTOP_AUDIO="true" ;;
    --with-microphone-audio) MICROPHONE_AUDIO="true" ;;
    output | region) SCOPE="$arg" ;;
  esac
done

start_screenrecording() {
  local filepath="${rec_dir}/rec_$(date +%H-%M-%S).mp4"
  local audio_devices=""
  local audio_args=()

  [[ $DESKTOP_AUDIO == "true" ]] && audio_devices+="default_output"
  echo $audio_devices

  if [[ $MICROPHONE_AUDIO == "true" ]]; then
    echo withmic
    # Merge audio tracks into one - separate tracks only play one at a time in most players
    [[ -n $audio_devices ]] && audio_devices+="|"
    audio_devices+="default_input"
  fi

  [[ -n $audio_devices ]] && audio_args+=(-a "$audio_devices" -ac aac)

  gpu-screen-recorder -w "$@" -fallback-cpu-encoding yes \
    -o "$filepath" "${audio_args[@]}" &
  local pid=$!

  # Wait for recording to actually start (file appears after portal selection)
  while kill -0 $pid 2>/dev/null && [[ ! -f $filepath ]]; do
    sleep 0.2
  done

  if kill -0 $pid 2>/dev/null; then
    echo "$filepath" >"$RECORDING_FILE"
  fi
}

stop_screenrecording() {
  pkill -SIGINT -f $proc_name # SIGINT required to save video properly

  # Wait a maximum of 5 seconds to finish before hard killing
  local count=0
  while pgrep -f $proc_name >/dev/null && ((count < 50)); do
    sleep 0.1
    count=$((count + 1))
  done

  if pgrep -f $proc_name >/dev/null; then
    pkill -9 -f $proc_name
    say "Recording process had to be force-killed. Video may be corrupted." -u critical
  else
    trim_first_frame
    local filename=$(cat "$RECORDING_FILE" 2>/dev/null)

    (
      ACTION=$(say "Recording saved to $rec_dir, click to open" -t 2000 -A "default=open")
      [[ $ACTION == "default" ]] && mpv "$filename"
    ) &
  fi

  rm -f "$RECORDING_FILE"
}

# Trim the first 100ms of the video to avoid the noise problem
trim_first_frame() {
  local latest
  latest=$(cat "$RECORDING_FILE" 2>/dev/null)

  if [[ -n $latest && -f $latest ]]; then
    local trimmed="${latest%.mp4}-trimmed.mp4"
    if ffmpeg -y -ss 0.1 -i "$latest" -c copy "$trimmed" -loglevel quiet 2>/dev/null; then
      mv "$trimmed" "$latest"
    else
      rm -f "$trimmed"
    fi
  fi
}

screenrecording_active() {
  pgrep -f $proc_name >/dev/null || pgrep -x slurp >/dev/null
}

if screenrecording_active; then
  if pgrep -x slurp >/dev/null; then
    pkill -x slurp 2>/dev/null
  else
    stop_screenrecording
  fi
  exit 0
fi

case $SCOPE in
  output) start_screenrecording "$(slurp -o -f "%o")" ;;
  region) start_screenrecording "$(slurp -f "%wx%h+%x+%y")" ;;
esac
